# Copy this file to terraform.tfvars and fill in real values.
# terraform.tfvars is git-ignored — never commit it.

aws_region   = "ap-south-1"
environment  = "production"
alert_email  = "your-email@example.com"

# Adjust instance class if needed
db_instance_class = "db.t3.small"

# Dashboard UI — Amplify hosting
amplify_github_repo = "https://github.com/iraviagrollp/iravi-ui"
dashboard_username  = "admin"
dashboard_password  = "iravi@2024"

# Bastion host — required for SQL client access to RDS
# 1. Create key pair in AWS Console → EC2 → Key Pairs → Create key pair
#    Name: iravi-dashboard-bastion  Format: .pem  → Download and store safely
# 2. Find your public IP: curl https://ifconfig.me
bastion_key_name     = "iravi-dashboard-bastion"
bastion_allowed_cidr = "YOUR_IP/32"  # e.g. "203.0.113.45/32"

# Alerts / SES — sender identity for balance-alert emails
# After apply, run: terraform output ses_dkim_tokens
# Add the 3 output CNAME records to your DNS provider to verify the domain.
# Also request SES production access (sandbox → production) in the AWS console.
alerts_sender_email = "noreply@iraviagrolife.com"
alerts_domain       = "iraviagrolife.com"
