    %% ── Snapshot Tables ─────────────────────────────────────

    class snapshot_stock {
        <<Snapshot>>
        +int           id                    PK
        +Date          snapshot_date
        +int           s_no
        +String        product_brand_name
        +String        product_chemical_name
        +int           packing_id            FK
        +Decimal       qty_ap_current
        +Decimal       qty_ts_current
        +Decimal       qty_ap_previous
        +Decimal       qty_ts_previous
        +Decimal       total_qty_current
        +Decimal       total_qty_previous
        +Decimal       rate
        +Decimal       opening_value
        +Decimal       closing_value
        +DateTime      ingested_at
    }

    class snapshot_stock_margin {
        <<Snapshot>>
        +int           id                 PK
        +Date          snapshot_date
        +String        product_brand_name
        +int           packing_id         FK
        +Decimal       cost_price
        +Decimal       margin_pct
        +Decimal       nrv_price
        +Decimal       nrv
        +DateTime      ingested_at
    }

    class snapshot_customer_balances {
        <<Snapshot>>
        +int           id             PK
        +Date          snapshot_date
        +String        branch
        +String        customer_name
        +String        customer_code
        +String        city
        +Decimal       debit
        +Decimal       credit
        +Decimal       balance_amount
        +String        balance_type
        +DateTime      ingested_at
    }

    %% ── Audit ───────────────────────────────────────────────

    class etl_runs {
        <<Audit>>
        +int           id              PK
        +Date          run_date        UK
        +DateTime      started_at
        +DateTime      completed_at
        +String        status
        +JSON          files_processed
        +String        error_message
    }

    %% ── Relationships ───────────────────────────────────────

    %% Hard FK constraints
    dim_packings "1" --> "0..*" snapshot_stock         : packing_id
    dim_packings "1" --> "0..*" snapshot_stock_margin  : packing_id

    %% Soft joins via party_name / customer_name (no DB-level FK)
    dim_customers "1" ..> "0..*" fact_sales                    : party_name
    dim_customers "1" ..> "0..*" fact_sales_returns             : party_name
    dim_customers "1" ..> "0..*" snapshot_customer_balances     : customer_name
