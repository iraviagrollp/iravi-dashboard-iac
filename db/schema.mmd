classDiagram
    direction TB

    %% ── Dimensions ──────────────────────────────────────────

    class dim_customers {
        <<Dimension>>
        +int           id              PK
        +String        customer_name   UK
        +String        customer_code
        +String        parent_group
        +String        contact_person
        +String        gstn
        +String        gst_reg_type
        +String        city
        +String        state
        +String        pin
        +String        mobile_no
        +String        alt_mobile_no
        +String        email
        +String        pan
        +String        licence_no
        +DateTime      ingested_at
    }

    class dim_packings {
        <<Dimension>>
        +int           id                  PK
        +String        packing_description UK
        +DateTime      ingested_at
    }

    %% ── Fact Tables ─────────────────────────────────────────

    class fact_sales {
        <<Fact>>
        +int           id               PK
        +Date          transaction_date
        +String        voucher_no       UK
        +String        branch
        +String        party_name
        +String        party_gstn
        +Decimal       qty
        +Decimal       gross
        +Decimal       discount
        +Decimal       assessable_value
        +Decimal       cgst
        +Decimal       sgst
        +Decimal       igst
        +Decimal       net
        +Decimal       bill_value
        +DateTime      ingested_at
    }

    class fact_sales_returns {
        <<Fact>>
        +int           id               PK
        +Date          transaction_date
        +String        voucher_no       UK
        +String        branch
        +String        location
        +String        storage_bin
        +String        party_name
        +String        party_gstn
        +String        ref_bill_no
        +Date          ref_bill_date
        +Decimal       qty
        +Decimal       gross
        +Decimal       discount
        +Decimal       mrp_amount
        +Decimal       gmd
        +Decimal       assessable_value
        +Decimal       cgst
        +Decimal       sgst
        +Decimal       igst
        +Decimal       net
        +Decimal       charges
        +Decimal       charges_cgst
        +Decimal       charges_sgst
        +Decimal       charges_igst
        +Decimal       deductions
        +Decimal       adjustments
        +Decimal       roundoff
        +Decimal       bill_value
        +String        remarks
        +DateTime      ingested_at
    }

    class fact_purchases {
        <<Fact>>
        +int           id               PK
        +Date          transaction_date
        +String        voucher_no       UK
        +String        branch
        +String        party_name
        +String        party_gstn
        +Date          ref_bill_date
        +Decimal       qty
        +Decimal       gross
        +Decimal       cgst
        +Decimal       sgst
