    class fact_expenses {
        <<Fact>>
        +int           id               PK
        +Date          transaction_date
        +String        voucher_no       UK
        +String        branch
        +String        party_name
        +String        party_gstn
        +Date          ref_bill_date
        +Decimal       qty
        +Decimal       gross
        +Decimal       cgst
        +Decimal       sgst
