    class fact_purchase_returns {
        <<Fact>>
        +int           id               PK
        +Date          transaction_date
        +String        voucher_no       UK
        +String        branch
        +String        party_name
        +Date          ref_bill_date
        +String        product_name     UK
        +Decimal       qty
        +Decimal       rate
        +Decimal       gross
        +Decimal       disc_rate
        +Decimal       discount
        +Decimal       mrp
        +Decimal       gmd
        +Decimal       assessable_value
        +Decimal       cgst_rate
        +Decimal       cgst
        +Decimal       sgst_rate
        +Decimal       sgst
        +Decimal       igst_rate
        +Decimal       igst
        +Decimal       net
        +String        barcodes
        +String        narration
        +DateTime      ingested_at
